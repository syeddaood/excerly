{
  "expo": {
    "name": "DawnLock",
    "slug": "dawnlock",
    "version": "0.0.1",
    "scheme": "dawnlock",
    "orientation": "portrait",
    "userInterfaceStyle": "automatic",
    "plugins": [
      "./modules/android-alarm/app.plugin.js",
      "expo-router",
      "expo-asset",
      "expo-font"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.dawnlock.app"
    },
    "android": {
      "package": "com.dawnlock.app",
      "permissions": [
        "SCHEDULE_EXACT_ALARM",
        "USE_EXACT_ALARM",
        "RECEIVE_BOOT_COMPLETED",
        "FOREGROUND_SERVICE",
        "FOREGROUND_SERVICE_MEDIA_PLAYBACK",
        "WAKE_LOCK",
        "VIBRATE",
        "POST_NOTIFICATIONS",
        "USE_FULL_SCREEN_INTENT"
      ],
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": false,
          "data": [
            {
              "scheme": "dawnlock"
            }
          ],
          "category": ["BROWSABLE", "DEFAULT"]
        }
      ]
    }
  }
}
